# Socket.IO signaling server URL
# Local dev: http://localhost:3001
# Production: https://your-server.railway.app (deploy server/ to Railway/Render/Fly.io)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Server port (used by server/index.js)
PORT=3001

# Allowed origin for Socket.IO CORS (set to your Vercel URL in production)
CLIENT_URL=http://localhost:3000
